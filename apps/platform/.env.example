# =============================================================================
# White-Label Portal — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing actual secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Tenant Configuration
# -----------------------------------------------------------------------------
# UUID of the tenant in the tenants table. Each white-label deployment
# must have its own tenant record. If not set, falls back to the default
# platform default tenant for development.
TENANT_ID=

# Override tenant branding via env vars (optional — DB values take precedence)
TENANT_NAME=
TENANT_SHORT_NAME=
TENANT_EMAIL=
TENANT_WEBSITE_URL=
TENANT_LOGO_URL=
TENANT_PRIMARY_COLOR=
TENANT_SECONDARY_COLOR=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
STRIPE_PAYMENT_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# n8n Webhooks
# -----------------------------------------------------------------------------
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_REMARKETING_WEBHOOK_URL=
N8N_WEBHOOK_APPLICATION_SUBMIT=
N8N_WEBHOOK_APPLICATION_REVIEW=
N8N_WEBHOOK_ENROLLMENT_CONFIRMED=

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_PORTAL_URL=http://localhost:3002
NEXT_PUBLIC_SITE_NAME=Your School Name

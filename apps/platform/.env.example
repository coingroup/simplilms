# =============================================================================
# SimpliLMS Platform — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file containing actual secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Tenant Configuration
# -----------------------------------------------------------------------------
# UUID of the tenant in the tenants table. Each deployment has exactly one
# tenant. If not set, falls back to the default development tenant.
TENANT_ID=

# Override tenant branding via env vars (optional — DB values take precedence)
TENANT_NAME=
TENANT_SHORT_NAME=
TENANT_EMAIL=
TENANT_WEBSITE_URL=
TENANT_LOGO_URL=
TENANT_PRIMARY_COLOR=
TENANT_SECONDARY_COLOR=

# Public branding vars (bundled into client JS)
NEXT_PUBLIC_PORTAL_NAME=
NEXT_PUBLIC_PORTAL_SHORT_NAME=
NEXT_PUBLIC_PORTAL_DESCRIPTION=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_WEBSITE_URL=
NEXT_PUBLIC_LOCATION=
NEXT_PUBLIC_TRADEMARK=
NEXT_PUBLIC_PRIMARY_COLOR=#F26822
NEXT_PUBLIC_SECONDARY_COLOR=#FFCE38
NEXT_PUBLIC_ACCENT_COLOR=#FAA62E

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
STRIPE_PAYMENT_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Anthropic (AI Course Creator)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# n8n Webhooks (optional — platform works without these)
# -----------------------------------------------------------------------------
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_REMARKETING_WEBHOOK_URL=
N8N_WEBHOOK_APPLICATION_SUBMIT=
N8N_WEBHOOK_APPLICATION_REVIEW=
N8N_WEBHOOK_ENROLLMENT_CONFIRMED=

# -----------------------------------------------------------------------------
# Feature Flags (optional — defaults to false if not set)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FEATURE_ISA=false
NEXT_PUBLIC_FEATURE_ZOOM=false
NEXT_PUBLIC_FEATURE_STRIPE_CONNECT=false
NEXT_PUBLIC_FEATURE_LMS=true
NEXT_PUBLIC_FEATURE_AI_COURSE=false
NEXT_PUBLIC_FEATURE_CERTIFICATES=false
NEXT_PUBLIC_FEATURE_QUIZZES=true

# Sector module flags
NEXT_PUBLIC_SECTOR_REAL_ESTATE=false
NEXT_PUBLIC_SECTOR_INSURANCE=false
NEXT_PUBLIC_SECTOR_HEALTHCARE=false
NEXT_PUBLIC_SECTOR_CDL=false
NEXT_PUBLIC_SECTOR_COSMETOLOGY=false
NEXT_PUBLIC_SECTOR_IT_TECH=false
NEXT_PUBLIC_SECTOR_CORPORATE=false
NEXT_PUBLIC_SECTOR_GOVERNMENT=false

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Your School Name

{
  "name": "@simplilms/core",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./actions/*": "./src/actions/*.ts",
    "./context": "./src/context/index.ts"
  },
  "typesVersions": {
    "*": {
      "components/*": ["./src/components/*.tsx"],
      "lib/*": ["./src/lib/*.ts"],
      "actions/*": ["./src/actions/*.ts"],
      "context": ["./src/context/index.ts"]
    }
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules .turbo"
  },
  "dependencies": {
    "@simplilms/auth": "*",
    "@simplilms/database": "*",
    "@simplilms/ui": "*",
    "@hookform/resolvers": "^3.9.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.0",
    "lucide-react": "^0.468.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^1.7.1",
    "stripe": "^20.4.1",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@simplilms/config": "*",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  }
}
